# Maintainer: zenox444x <https://github.com/zenox444x>
pkgname=wit
pkgver=4.0.0
pkgrel=2
pkgdesc="Windows Is Trash — CachyOS app installer, gaming tools, and system fixer (GTK4)"
arch=('any')
url="https://github.com/zenox444x/WIT"
license=('MIT')
depends=(
    'python'
    'python-gobject'
    'gtk4'
    'libadwaita'
)
optdepends=(
    'yay: required for AUR package installation'
    'bluez: for bluetooth fixes'
    'networkmanager: for wi-fi fixes'
    'gamemode: for gaming performance'
)

source=(
    "wit.py::https://raw.githubusercontent.com/zenox444x/WIT/main/WIT/wit.py"
)
sha256sums=('SKIP')

package() {
    # ── Main script → /usr/lib/wit/wit.py ──────────────────────────────────
    install -Dm755 "${srcdir}/wit.py" "${pkgdir}/usr/lib/wit/wit.py"

    # ── Launcher wrapper → /usr/bin/wit ────────────────────────────────────
    install -dm755 "${pkgdir}/usr/bin"
    cat > "${pkgdir}/usr/bin/wit" << 'EOF'
#!/bin/bash
exec python3 /usr/lib/wit/wit.py "$@"
EOF
    chmod 755 "${pkgdir}/usr/bin/wit"

    # ── Desktop entry ───────────────────────────────────────────────────────
    install -dm755 "${pkgdir}/usr/share/applications"
    cat > "${pkgdir}/usr/share/applications/wit.desktop" << 'EOF'
[Desktop Entry]
Name=WIT
GenericName=CachyOS Toolkit
Comment=Windows Is Trash — Install apps and fix system issues on CachyOS
Exec=/usr/bin/wit
Icon=wit
Terminal=false
Type=Application
Categories=System;PackageManager;Settings;
Keywords=install;packages;yay;aur;bluetooth;wifi;cachy;gaming;
StartupNotify=true
StartupWMClass=wit
EOF
}
